{
  "manifest_version": 3,
  "name": "Zealer Dashboard",
  "version": "2.25.0",
  "description": "Engineering delivery cockpit \u2014 sprint health, reliability alerts, and time tracking, in a Chrome side panel.",
  "author": "Zeal",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Zealer Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "tabs",
    "downloads",
    "identity"
  ],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://o164516.ingest.us.sentry.io/*",
    "https://api.github.com/*",
    "https://*.sentry.io/*",
    "https://sentry.io/*",
    "https://calendar.google.com/*",
    "https://*.google.com/*",
    "https://*.googleusercontent.com/*",
    "https://www.googleapis.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "settings.html",
  "minimum_chrome_version": "114",
  "key": "",
  "oauth2": {
    "client_id": "PASTE_YOUR_CHROME_EXTENSION_OAUTH_CLIENT_ID.apps.googleusercontent.com",
    "scopes": [
      "https://www.googleapis.com/auth/calendar.readonly"
    ]
  }
}
