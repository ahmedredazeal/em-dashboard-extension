{
  "manifest_version": 3,
  "name": "Zealer Dashboard",
  "version": "2.6.11",
  "description": "Engineering delivery cockpit \u2014 sprint health, reliability alerts, and time tracking, in a Chrome side panel.",
  "author": "Zeal",
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "action": {
    "default_title": "Zealer Dashboard",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "background": {
    "service_worker": "background.js",
    "type": "module"
  },
  "side_panel": {
    "default_path": "popup.html"
  },
  "permissions": [
    "storage",
    "alarms",
    "notifications",
    "sidePanel",
    "tabs"
  ],
  "host_permissions": [
    "https://*.atlassian.net/*",
    "https://zeal.sentry.io/*",
    "https://sentry.io/*",
    "https://docs.google.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'"
  },
  "options_page": "settings.html",
  "minimum_chrome_version": "114"
}